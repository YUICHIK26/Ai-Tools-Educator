# AI Tools Educator - Environment Variables
# Copy this file to .env and fill in your actual credentials

# User Display Name
Username=User

# Cohere API Key (for decision-making model routing)
# Get your API key from: https://dashboard.cohere.com/
CohereAPIKey=YOUR_COHERE_API_KEY

# Groq API Key (for conversational chatbot responses)
# Get your API key from: https://console.groq.com/keys
GroqAPIKey=YOUR_GROQ_API_KEY

# ElevenLabs API Key (for text-to-speech)
# Get your API key from: https://elevenlabs.io/app/speech-synthesis
ElevenLabsAPIKey=YOUR_ELEVENLABS_API_KEY

# Firebase Configuration (for authentication and database)
# Get your credentials from Firebase Console: https://console.firebase.google.com/
FirebaseAPIKey=YOUR_FIREBASE_API_KEY
FirebaseAuthDomain=YOUR_FIREBASE_AUTH_DOMAIN
FirebaseProjectId=YOUR_FIREBASE_PROJECT_ID
FirebaseStorageBucket=YOUR_FIREBASE_STORAGE_BUCKET
FirebaseMessagingSenderId=YOUR_FIREBASE_MESSAGING_SENDER_ID
FirebaseAppId=YOUR_FIREBASE_APP_ID

# Tesseract OCR Configuration (for screen text recognition)
TesseractPath=C:\\Program Files\\Tesseract-OCR\\tesseract.exe

# Optional: Anthropic Claude API Key (if adding Claude support)
# ClaudeAPIKey=YOUR_CLAUDE_API_KEY

# Optional: OpenAI API Key (if adding OpenAI models)
# OpenAIAPIKey=YOUR_OPENAI_API_KEY
